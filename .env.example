# Shared database credentials
DB_USERNAME=root
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# Local service discovery and messaging
EUREKA_URL=http://localhost:8761/eureka/
EUREKA_INSTANCE_HOSTNAME=localhost
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AI_SERVICE_URL=http://localhost:8085
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Docker-only endpoints
DOCKER_EUREKA_URL=http://eureka-server:8761/eureka/
DOCKER_EUREKA_HOSTNAME=eureka-server
DOCKER_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
DOCKER_AI_SERVICE_URL=http://ai-service:8085

# Local IDE datasource URLs
AUTH_DATASOURCE_URL=jdbc:mysql://localhost:3306/resume_auth_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
RESUME_DATASOURCE_URL=jdbc:mysql://localhost:3306/resume_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
EXPORT_DATASOURCE_URL=jdbc:mysql://localhost:3306/resume_export_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
TEMPLATE_DATASOURCE_URL=jdbc:mysql://localhost:3306/resume_ai_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
JOBMATCH_DATASOURCE_URL=jdbc:mysql://localhost:3306/resume_jobmatch_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Docker datasource URLs
AUTH_DOCKER_DATASOURCE_URL=jdbc:mysql://mysql:3306/resume_auth_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
RESUME_DOCKER_DATASOURCE_URL=jdbc:mysql://mysql:3306/resume_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
EXPORT_DOCKER_DATASOURCE_URL=jdbc:mysql://mysql:3306/resume_export_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
TEMPLATE_DOCKER_DATASOURCE_URL=jdbc:mysql://mysql:3306/resume_ai_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
JOBMATCH_DOCKER_DATASOURCE_URL=jdbc:mysql://mysql:3306/resume_jobmatch_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
EMAIL_USERNAME=dev@example.com
EMAIL_PASSWORD=change-me
AUTH_EMAIL_USERNAME=dev-auth@example.com
AUTH_EMAIL_PASSWORD=change-me
NOTIFICATION_EMAIL_USERNAME=dev-notification@example.com
NOTIFICATION_EMAIL_PASSWORD=change-me

# Auth and OAuth
OAUTH2_REDIRECT_PROTO=http
OAUTH2_REDIRECT_HOST=localhost:8080
OAUTH2_REDIRECT_PORT=8080
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
JWT_SECRET=replace-with-a-long-random-secret

# Gemini
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
GEMINI_API_KEY=your-gemini-api-key
GEMINI_FALLBACK_URLS=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent

# AWS S3
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_BUCKET_NAME=your-s3-bucket
AWS_REGION=ap-southeast-2

# Third-party APIs
RAPIDAPI_KEY=your-rapidapi-key
RAZORPAY_KEY=your-razorpay-key
RAZORPAY_SECRET=your-razorpay-secret
TEST_EMAIL=dev@example.com
